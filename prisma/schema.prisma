// Prisma schema for Setu marketplace

 generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  customer
  provider
  admin
}

enum ProviderOnboardingStatus {
  draft
  submitted
  needs_fix
  approved
  rejected
}

enum VerificationItemStatus {
  pending
  approved
  needs_fix
  rejected
}

enum UploadedFilePurpose {
  provider_id_document
  provider_selfie
  provider_portfolio
  provider_certificate
  provider_fssai
  provider_intro_video
  customer_request_photo
  chat_attachment
}

model User {
  id            String   @id @default(cuid())
  role          UserRole
  phone         String   @unique
  name          String?
  email         String?
  preferredLang String  @default("en")
  city          String?
  area          String?
  lat           Float?
  lng           Float?
  interests     Json     @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  providerProfile ProviderProfile?
  uploadedFiles   UploadedFile[]
}

model ProviderProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName     String?
  headline        String?
  bio             String   @default("")
  translatedBio   String?
  category        String?
  serviceIds      Json     @default("[]")
  serviceNames    Json     @default("[]")
  languages       Json     @default("[]")
  experienceLevel String?
  yearsExperience Int?

  city            String?
  area            String?
  neighborhood    String?
  serviceRadiusKm Int      @default(5)
  lat             Float?
  lng             Float?

  onboardingStatus ProviderOnboardingStatus @default(draft)
  trustScore        Int      @default(0)
  profileViews      Int      @default(0)
  submittedAt       DateTime?
  approvedAt        DateTime?
  rejectedAt        DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  services         ProviderService[]
  packages         ProviderPackage[]
  documents        ProviderDocument[]
  portfolio        PortfolioItem[]
  uploadedFiles    UploadedFile[]
  settings         ProviderServiceSettings?
  availability     AvailabilitySlot[]
  verification     ProviderVerificationStatus?
  leads            Lead[]
  bookings         Booking[]
  conversations    Conversation[]
  reviews          Review[]

  @@index([onboardingStatus])
  @@index([city, area])
}

model ProviderService {
  id          String   @id @default(cuid())
  providerId  String
  provider    ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  categoryId  String
  name        String
  description String @default("")
  active      Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([providerId])
  @@index([categoryId])
}

model ProviderPackage {
  id          String   @id @default(cuid())
  providerId  String
  provider    ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  name        String
  description String @default("")
  priceInr    Int
  durationMin Int?
  active      Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([providerId])
}

model ProviderServiceSettings {
  id                  String   @id @default(cuid())
  providerId          String   @unique
  provider            ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  customQuoteEnabled  Boolean @default(true)
  travelRadiusKm      Int     @default(10)
  neighborhoods       Json    @default("[]")
  blackoutDates       Json    @default("[]")
  weekendSurchargePct Int     @default(0)
  holidaySurchargePct Int     @default(0)
  acceptsCalls        Boolean @default(true)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model AvailabilitySlot {
  id          String   @id @default(cuid())
  providerId  String
  provider    ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  weekday     Int
  startTime   String
  endTime     String
  active      Boolean @default(true)

  @@index([providerId, weekday])
}

model UploadedFile {
  id          String   @id @default(cuid())
  ownerUserId String
  ownerUser   User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  providerId  String?
  provider    ProviderProfile? @relation(fields: [providerId], references: [id], onDelete: Cascade)

  bucket      String
  path        String
  publicUrl   String?
  mimeType    String?
  sizeBytes   Int?
  purpose     UploadedFilePurpose

  createdAt   DateTime @default(now())

  documents   ProviderDocument[]
  portfolioItems PortfolioItem[]

  @@index([ownerUserId])
  @@index([providerId])
  @@unique([bucket, path])
}

model ProviderDocument {
  id             String   @id @default(cuid())
  providerId     String
  provider       ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  uploadedFileId String?
  uploadedFile   UploadedFile? @relation(fields: [uploadedFileId], references: [id], onDelete: SetNull)

  type           String
  label          String
  status         VerificationItemStatus @default(pending)
  requiredFix    String?
  adminNotes     String?
  reviewedAt     DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([providerId])
  @@index([status])
}

model PortfolioItem {
  id             String   @id @default(cuid())
  providerId     String
  provider       ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  uploadedFileId String?
  uploadedFile   UploadedFile? @relation(fields: [uploadedFileId], references: [id], onDelete: SetNull)

  type           String   @default("image")
  title          String?
  caption        String?
  mediaUrl       String?
  verified       Boolean  @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([providerId])
}

model ProviderVerificationStatus {
  id                  String   @id @default(cuid())
  providerId          String   @unique
  provider            ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  status              ProviderOnboardingStatus @default(draft)
  expectedReviewHours Int      @default(48)
  missingItems        Json     @default("[]")
  submittedAt         DateTime?
  reviewedAt          DateTime?
  resubmittedAt       DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

enum LeadStatus {
  new
  viewed
  accepted
  declined
  quoted
}

enum BookingStatus {
  accepted
  confirmed
  in_progress
  completed
  cancelled
}

model Lead {
  id                String   @id @default(cuid())
  providerId        String
  provider          ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  customerName      String
  serviceTitle      String
  area              String?
  preferredLanguage String?
  budgetInr         Int?
  note              String   @default("")
  status            LeadStatus @default(new)
  urgent            Boolean  @default(false)
  respondedAt       DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([providerId, status])
  @@index([providerId, createdAt])
}

model Booking {
  id               String   @id @default(cuid())
  providerId       String
  provider         ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  customerName     String
  customerUserId   String?
  serviceTitle     String
  scheduledAt      DateTime
  status           BookingStatus @default(confirmed)
  amountInr        Int      @default(0)
  address          String?
  notes            String   @default("")
  isRepeatCustomer Boolean  @default(false)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([providerId, status])
  @@index([providerId, scheduledAt])
  @@index([customerUserId])
}

model Conversation {
  id            String   @id @default(cuid())
  providerId    String
  provider      ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  customerName  String
  lastMessage   String   @default("")
  lastMessageAt DateTime @default(now())
  unreadCount   Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([providerId, lastMessageAt])
}

model Review {
  id           String   @id @default(cuid())
  providerId   String
  provider     ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  customerName String
  rating       Int
  comment      String   @default("")

  createdAt    DateTime @default(now())

  @@index([providerId])
}
